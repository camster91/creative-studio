# Creative Studio — environment variable reference
#
# Copy this file to /root/.env on the Coolify host, then fill in real values.
# Never commit a real .env file (it is in .gitignore as *.env and .env).
#
# Required: GEMINI_API_KEY (your Google AI Studio key, must start with AIza).
# Without it the app boots but every generation returns 502.

# ── Required for any generation to work ──
GEMINI_API_KEY=AIza-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Server-side fallback (BYOK is the default) ──
# When set to "true" (1/true/yes), the server's GEMINI_API_KEY above is used
# as a fallback for users who don't bring their own. Default is "false" —
# users must paste their own key in the editor sidebar.
#
# Set this to "true" only for demo / share-with-friends deployments where
# you don't want users to need their own key. Production = false.
CREATIVE_ALLOW_SERVER_FALLBACK=false

# ── Data and output directories ──
# Defaults shown — only override if mounting volumes elsewhere.
CREATIVE_DATA_DIR=/app/data
CREATIVE_OUTPUT_DIR=/app/outputs

# ── Daily cost limit per IP, in USD ──
# Generations beyond this get a 429. Set to 0 to disable.
CREATIVE_DAILY_LIMIT=5

# ── Flask session secret ──
# Optional. If unset, a random key is generated per restart (sessions reset).
# For multi-worker or persistent sessions, set a fixed value.
# FLASK_SECRET_KEY=your-long-random-string-here

# ── Rate limiting (in-memory, per-worker) ──
# Max requests per minute per IP for /api/* endpoints. Default 60.
# RATE_LIMIT_PER_MINUTE=60
